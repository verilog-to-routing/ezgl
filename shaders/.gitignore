# Generated by qsb at build time — never committed.
# Source of truth is the *.vert / *.frag siblings; the CMake build bakes
# them into ${build}/ezgl_rhi_shaders/*.qsb. An accidental in-tree bake
# (e.g. `qsb -o shaders/foo.vert.qsb shaders/foo.vert`) must not pollute
# the working tree.
*.qsb

# Generated by configure_file from shaders.qrc.in into the build dir.
shaders.qrc
