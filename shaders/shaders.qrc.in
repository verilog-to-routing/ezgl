<RCC>
    <qresource prefix="/ezgl">
        <file alias="line.vert.qsb">@EZGL_LINE_VERT_QSB@</file>
        <file alias="line.frag.qsb">@EZGL_LINE_FRAG_QSB@</file>
        <file alias="overlay.vert.qsb">@EZGL_OVERLAY_VERT_QSB@</file>
        <file alias="overlay.frag.qsb">@EZGL_OVERLAY_FRAG_QSB@</file>
        <file alias="thick_line.vert.qsb">@EZGL_THICK_LINE_VERT_QSB@</file>
        <file alias="dashed_line.vert.qsb">@EZGL_DASHED_LINE_VERT_QSB@</file>
        <file alias="dashed_line.frag.qsb">@EZGL_DASHED_LINE_FRAG_QSB@</file>
    </qresource>
</RCC>
